{
  "name": "pulse-coder-plugin-kit",
  "version": "0.0.1",
  "description": "Toolkit package for Pulse Coder runtime plugins",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./worktree": {
      "types": "./dist/worktree.d.ts",
      "import": "./dist/worktree.js",
      "require": "./dist/worktree.cjs"
    },
    "./vault": {
      "types": "./dist/vault.d.ts",
      "import": "./dist/vault.js",
      "require": "./dist/vault.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    },
    "./src": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./src/worktree": {
      "types": "./src/worktree/index.ts",
      "import": "./src/worktree/index.ts"
    },
    "./src/vault": {
      "types": "./src/vault/index.ts",
      "import": "./src/vault/index.ts"
    },
    "./src/devtools": {
      "types": "./src/devtools/index.ts",
      "import": "./src/devtools/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types:maybe",
    "build:js": "tsup",
    "build:types": "tsc -p tsconfig.types.json",
    "build:types:maybe": "if [ \"$SKIP_DTS\" = \"1\" ] || [ \"$TSUP_SKIP_DTS\" = \"1\" ]; then echo 'Skipping plugin-kit DTS build'; else pnpm run build:types; fi",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "pulse-coder-engine": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
